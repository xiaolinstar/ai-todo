# Copy to .env.production and fill in secrets before deploy:
#   cp .env.production.example .env.production

# PostgreSQL (used by docker-compose.prod.yml)
POSTGRES_DB=ai_todo
POSTGRES_USER=ai_todo
POSTGRES_PASSWORD=change-me-to-a-strong-password

# API
AI_TODO_PORT=3100
AI_TODO_PUBLISH_PORT=3100
AI_TODO_TIMEZONE=Asia/Shanghai

# Production MUST disable dev auth bypass (no anonymous user_dev)
AI_TODO_ALLOW_DEV_AUTH=false

# WeChat miniapp login (required for miniapp auth in production)
# AI_TODO_WECHAT_APP_ID=wx...
# AI_TODO_WECHAT_APP_SECRET=...

# Rate limiting (Phase C3)
AI_TODO_RATE_LIMIT_ENABLED=true
AI_TODO_RATE_LIMIT_WECHAT_LOGIN_PER_MINUTE=10

# TLS overlay (docker-compose.tls.yml)
# API_DOMAIN=api.example.com
# API_UPSTREAM=api:3100

# Optional: only used when AI_TODO_ALLOW_DEV_AUTH=true (local/dev)
# AI_TODO_DEV_USER_ID=user_dev
# AI_TODO_DEV_USER_DISPLAY_NAME=开发用户
