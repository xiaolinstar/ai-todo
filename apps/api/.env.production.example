# Copy to .env.production and fill in secrets before deploy:
#   cp .env.example .env
#   cp .env.production.example .env.production
#
# Load order used by deploy scripts:
#   .env first, then .env.production overrides it.

# PostgreSQL (used by docker-compose.prod.yml)
POSTGRES_DB=ai_todo
POSTGRES_USER=ai_todo
POSTGRES_PASSWORD=change-me-to-a-strong-password
# 密码可含 @/# 等；entrypoint 自动 URL 编码。改密码后请运行 scripts/rotate_postgres_password.py（见 docs/deploy.md）

# API 端口（与 xiaolin-docs:8080 / xiaolin-life:8081 对齐）
# Docker Compose 项目名会决定容器 / 网络 / volume 前缀，例如 ai-todo-production-api-1。
# 已上线环境修改该值前，请先确认 PostgreSQL volume 迁移或复用方案。
AI_TODO_COMPOSE_PROJECT_NAME=ai-todo-production

# 宿主机映射端口 — gateway 反代目标，生产默认 8082
AI_TODO_PUBLISH_PORT=8082
# 容器内监听端口 — 一般保持 3100，勿与 AI_TODO_PUBLISH_PORT 混淆

# Production MUST disable dev auth bypass (no anonymous user_dev)
AI_TODO_ALLOW_DEV_AUTH=false
AI_TODO_ENVIRONMENT=production

# WeChat miniapp login (required for miniapp auth in production)
# AI_TODO_WECHAT_APP_ID=wx...
# AI_TODO_WECHAT_APP_SECRET=...
# AI_TODO_WECHAT_REMINDER_TEMPLATE_ID=

# Rate limiting (Phase C3)
AI_TODO_RATE_LIMIT_ENABLED=true
AI_TODO_RATE_LIMIT_WECHAT_LOGIN_PER_MINUTE=10

# Deploy metadata shown by /v1/health. CD fills these automatically.
# AI_TODO_RELEASE_TAG=v0.1.2
# AI_TODO_GIT_SHA=

# Notification worker
AI_TODO_NOTIFICATION_WORKER_POLL_SECONDS=30
AI_TODO_NOTIFICATION_WORKER_BATCH_SIZE=50
AI_TODO_NOTIFICATION_MAX_ATTEMPTS=3

# Docker 构建（国内 VPS server-build 默认腾讯云源）
# PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
# APT_MIRROR=mirrors.tencent.com

# 部署后保留的 API 镜像 digest 数量（便于回滚，其余 prune）
# AI_TODO_IMAGE_RETENTION=3

# GHCR 拉取（public 包；未设置时脚本默认 ghcr.nju.edu.cn，CD 也会自动注入）
# 直连 ghcr.io：AI_TODO_PULL_REGISTRY_MIRROR=none
# AI_TODO_PULL_REGISTRY_MIRROR=ghcr.nju.edu.cn

# TLS：使用 xiaolin-gateway 反代 https://xingxiaolin.cn → 宿主机 :8082（勿启用 docker-compose.tls.yml）

# Optional: only used when AI_TODO_ALLOW_DEV_AUTH=true (local/dev)
# AI_TODO_DEV_USER_ID=user_dev
# AI_TODO_DEV_USER_DISPLAY_NAME=开发用户
