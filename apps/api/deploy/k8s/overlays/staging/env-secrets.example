# Staging Kubernetes overlay secrets (local only — gitignored as .env.*).
#   cp env-secrets.example .env.staging.secrets
# 从 VPS 上的 apps/api/.env.staging 抄入同名变量即可。

POSTGRES_PASSWORD=
AI_TODO_WECHAT_APP_ID=
AI_TODO_WECHAT_APP_SECRET=
AI_TODO_WECHAT_REMINDER_TEMPLATE_ID=

# Optional — entrypoint builds URL from POSTGRES_* when unset.
# AI_TODO_DATABASE_URL=
