# Copy to .env.staging on the staging VPS and fill secrets before deploy:
#   cp .env.example .env
#   cp .env.staging.example .env.staging
#
# Deploy with:
#   ENV_FILE=.env.staging apps/api/deploy/remote-deploy.sh
#
# Load order used by deploy scripts:
#   .env first, then .env.staging overrides it.

POSTGRES_DB=ai_todo
POSTGRES_USER=ai_todo
POSTGRES_PASSWORD=change-me-to-a-strong-staging-password

# Staging should use its own host port and gateway upstream.
AI_TODO_PUBLISH_PORT=8083
AI_TODO_ENVIRONMENT=staging
AI_TODO_ALLOW_DEV_AUTH=false

# WeChat miniapp login. Prefer a staging/test AppID where possible.
# AI_TODO_WECHAT_APP_ID=wx...
# AI_TODO_WECHAT_APP_SECRET=...
# AI_TODO_WECHAT_REMINDER_TEMPLATE_ID=

# Deploy metadata shown by /v1/health. CD fills these automatically.
# AI_TODO_RELEASE_TAG=v0.0.0-staging
# AI_TODO_GIT_SHA=

# Docker build / pull defaults for domestic VPS.
PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
APT_MIRROR=mirrors.tencent.com
# AI_TODO_PULL_REGISTRY_MIRROR=ghcr.nju.edu.cn

# Keep a few image digests for quick rollback.
AI_TODO_IMAGE_RETENTION=3
