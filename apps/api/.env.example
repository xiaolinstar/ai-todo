# Common non-secret defaults shared by local / staging / production.
#
# Copy to .env when you want a shared base env file:
#   cp .env.example .env
#
# Load order used by project scripts:
#   .env first, then .env.local / .env.staging / .env.production overrides it.
#
# Keep this file free of secrets. Put passwords, tokens, AppSecret, PAT, and
# deployment credentials in the environment-specific file or GitHub Secrets.
#
# Local-only settings (environment name, publish port, dev auth, dev user) live in
# .env.local.example — not here. Container listen port defaults to 3100 in
# Dockerfile / docker-compose; override only if you have a special need.

AI_TODO_TIMEZONE=Asia/Shanghai
AI_TODO_STRUCTURED_LOGS_ENABLED=true
AI_TODO_METRICS_ENABLED=true
AI_TODO_METRICS_PATH=/metrics

AI_TODO_ICP_BEIAN_TEXT=苏ICP备2026011017号-7
AI_TODO_PUBLIC_SECURITY_BEIAN_TEXT=苏公网安备32010602012480号

AI_TODO_RATE_LIMIT_ENABLED=true
AI_TODO_RATE_LIMIT_WECHAT_LOGIN_PER_MINUTE=10

AI_TODO_NOTIFICATION_WORKER_POLL_SECONDS=30
AI_TODO_NOTIFICATION_WORKER_BATCH_SIZE=50
AI_TODO_NOTIFICATION_MAX_ATTEMPTS=3

# Docker build defaults. VPS environment files can override these with
# China-friendly mirrors.
PIP_INDEX_URL=https://pypi.org/simple
