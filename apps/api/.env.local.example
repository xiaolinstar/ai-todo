# Copy to .env.local for local Docker Compose development:
#   cp .env.local.example .env.local
#
# Optional shared defaults:
#   cp .env.example .env
#
# Start (local Docker; loads WeChat secrets from .env.local into api/worker):
#   COMPOSE_ENV_FILES=.env,.env.local docker compose --profile notifications up -d --build
# or:
#   AI_TODO_ENV_FILE=.env.local scripts/dev-up.sh

POSTGRES_DB=ai_todo
POSTGRES_USER=ai_todo
POSTGRES_PASSWORD=ai_todo

AI_TODO_PUBLISH_PORT=3100
AI_TODO_ENVIRONMENT=local
AI_TODO_ALLOW_DEV_AUTH=true

# Local Docker Compose builds default to the official PyPI index.
# If package downloads are slow, switch to a mirror.
PIP_INDEX_URL=https://pypi.org/simple
# PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple

# Optional: configure these only when testing real WeChat login locally.
# The AppID must match apps/miniapp/project.private.config.json.
# AI_TODO_WECHAT_APP_ID=wx...
# AI_TODO_WECHAT_APP_SECRET=...

# Optional: only needed when testing real WeChat subscribe messages.
# AI_TODO_WECHAT_REMINDER_TEMPLATE_ID=

AI_TODO_RATE_LIMIT_ENABLED=true
AI_TODO_RATE_LIMIT_WECHAT_LOGIN_PER_MINUTE=10

# Optional deploy metadata shown by /v1/health.
# AI_TODO_RELEASE_TAG=local
# AI_TODO_GIT_SHA=

AI_TODO_NOTIFICATION_WORKER_POLL_SECONDS=30
AI_TODO_NOTIFICATION_WORKER_BATCH_SIZE=50
AI_TODO_NOTIFICATION_MAX_ATTEMPTS=3
