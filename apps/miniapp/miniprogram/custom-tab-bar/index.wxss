@charset "UTF-8";
.tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 99;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(249, 249, 249, 0.94);
  border-top: 1rpx solid rgba(60, 60, 67, 0.12);
  backdrop-filter: blur(16px);
}

.tab-bar-inner {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 112rpx;
  padding: 0 8rpx;
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-width: 0;
  min-height: 96rpx;
  padding: 8rpx 0;
  border-radius: 16rpx;
}

.tab-item-hover {
  background: rgba(0, 0, 0, 0.05);
}

.tab-item.active .tab-text {
  color: #007aff;
  font-weight: 600;
}

.tab-text {
  color: #8e8e93;
  font-size: 20rpx;
  line-height: 1.2;
}

.tab-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}

.tab-icon.active.icon-reminder::before,
.tab-icon.active.icon-reminder::after,
.tab-icon.active.icon-calendar::before,
.tab-icon.active.icon-calendar::after,
.tab-icon.active.icon-contacts::before,
.tab-icon.active.icon-contacts::after,
.tab-icon.active.icon-mine::before,
.tab-icon.active.icon-mine::after {
  border-color: #007aff;
  background: #007aff;
}

/* Reminder — checklist */
.icon-reminder::before,
.icon-reminder::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.icon-reminder::before {
  top: 4rpx;
  left: 6rpx;
  width: 30rpx;
  height: 36rpx;
  border: 3rpx solid #8e8e93;
  border-radius: 8rpx;
}

.icon-reminder::after {
  top: 16rpx;
  left: 12rpx;
  width: 18rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #8e8e93;
  box-shadow: 0 8rpx 0 #8e8e93, 0 16rpx 0 #8e8e93;
}

/* Calendar */
.icon-calendar::before,
.icon-calendar::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.icon-calendar::before {
  top: 6rpx;
  left: 4rpx;
  width: 36rpx;
  height: 32rpx;
  border: 3rpx solid #8e8e93;
  border-radius: 8rpx;
}

.icon-calendar::after {
  top: 0;
  left: 10rpx;
  width: 24rpx;
  height: 8rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #8e8e93;
}

/* Contacts */
.icon-contacts::before,
.icon-contacts::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
  border: 3rpx solid #8e8e93;
  border-radius: 50%;
  background: transparent;
}

.icon-contacts::before {
  top: 4rpx;
  left: 2rpx;
  width: 18rpx;
  height: 18rpx;
}

.icon-contacts::after {
  top: 4rpx;
  left: 22rpx;
  width: 18rpx;
  height: 18rpx;
}

/* Mine */
.icon-mine::before,
.icon-mine::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.icon-mine::before {
  top: 2rpx;
  left: 12rpx;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #8e8e93;
  border-radius: 50%;
}

.icon-mine::after {
  top: 24rpx;
  left: 6rpx;
  width: 32rpx;
  height: 18rpx;
  border: 3rpx solid #8e8e93;
  border-top: none;
  border-radius: 0 0 18rpx 18rpx;
}

.tab-create-wrap {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 4rpx;
  min-width: 0;
  padding-bottom: 4rpx;
}

.tab-create {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  margin-top: -36rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #0a84ff 0%, #007aff 100%);
  box-shadow: 0 10rpx 28rpx rgba(0, 122, 255, 0.38);
}

.tab-create-hover {
  transform: scale(0.94);
  opacity: 0.92;
}

.tab-create-icon {
  margin-top: -4rpx;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

.tab-create-label {
  color: #8e8e93;
  font-size: 20rpx;
}