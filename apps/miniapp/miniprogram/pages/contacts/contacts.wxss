.contacts-page {
  padding-top: 16rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: var(--todo-surface-muted);
  font-size: 28rpx;
}

.search-btn {
  width: auto !important;
  min-height: 64rpx !important;
  padding: 0 24rpx !important;
  font-size: 26rpx !important;
}

.empty-card {
  padding: 48rpx 32rpx;
}

.contact-item {
  padding: 28rpx 32rpx;
}

.contact-name {
  color: var(--todo-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.fab-area {
  position: fixed;
  right: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  left: 32rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--todo-overlay);
}

.modal {
  width: 84%;
  margin: 0;
}

.modal-title {
  margin-bottom: 24rpx;
  color: var(--todo-text-primary);
  font-size: 32rpx;
  font-weight: 700;
}

.mt {
  margin-top: 16rpx;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.modal-actions button {
  flex: 1;
}