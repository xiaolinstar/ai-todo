<view class="page page-with-tab contacts-page">
  <view class="large-title-wrap">
    <view class="large-title">通讯录</view>
    <view class="large-subtitle" wx:if="{{loaded}}">{{items.length}} 位联系人</view>
  </view>

  <view class="search-group">
    <view class="search-wrap">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索姓名、邮箱或公司"
        value="{{query}}"
        bindinput="onQueryInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <text wx:if="{{query}}" class="link-text pressable" bindtap="onClearSearch" hover-class="pressable-active">清除</text>
    </view>
  </view>

  <view wx:if="{{loading && !loaded}}" class="loading-state">
    <view class="meta">加载中…</view>
  </view>
  <view wx:elif="{{error}}" class="error-banner">{{error}}</view>

  <block wx:elif="{{items.length === 0}}">
    <view class="empty-state inset-group">
      <view class="empty-icon">👤</view>
      <view class="empty-title">暂无联系人</view>
      <view class="empty-desc">点击底部 + 添加联系人</view>
    </view>
  </block>

  <block wx:else>
    <view class="inset-group">
      <view
        class="list-cell contact-row-inner pressable"
        wx:for="{{items}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onTapContact"
        hover-class="list-cell-hover"
      >
        <view class="avatar" style="background: {{item.avatarColor}};">{{item.initial}}</view>
        <view class="cell-body compact">
          <view class="cell-title">{{item.displayName}}</view>
          <view wx:if="{{item.subtitle}}" class="cell-subline">{{item.subtitle}}</view>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{showAddForm}}" class="sheet-mask" bindtap="hideAdd">
    <view class="sheet-panel" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-title">新建联系人</view>
      <view class="form-group">
        <view class="form-row stack">
          <text class="form-label">姓名</text>
          <input class="form-input" placeholder="必填" value="{{newName}}" bindinput="onNewNameInput" />
        </view>
        <view class="form-row stack">
          <text class="form-label">邮箱</text>
          <input class="form-input" placeholder="可选" value="{{newEmail}}" bindinput="onNewEmailInput" />
        </view>
      </view>
      <view class="sheet-actions">
        <button class="todo-button todo-button-secondary" hover-class="todo-button-hover" bindtap="hideAdd">取消</button>
        <button class="todo-button todo-button-primary" loading="{{adding}}" hover-class="todo-button-hover" bindtap="onAddContact">保存</button>
      </view>
    </view>
  </view>
</view>
