<view class="page page-with-tab contacts-page">
  <view class="large-title-wrap">
    <view class="large-title">通讯录</view>
    <view class="large-subtitle" wx:if="{{loaded}}">{{totalCount}} 位联系人</view>
  </view>

  <view class="search-group">
    <view class="search-wrap">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索姓名、邮箱或公司"
        value="{{query}}"
        bindinput="onQueryInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <text wx:if="{{query}}" class="link-text pressable" bindtap="onClearSearch" hover-class="pressable-active">清除</text>
    </view>
  </view>

  <view wx:if="{{loading && !loaded}}" class="loading-state">
    <view class="meta">加载中…</view>
  </view>
  <view wx:elif="{{error}}" class="error-banner">{{error}}</view>

  <block wx:elif="{{items.length === 0}}">
    <view class="empty-state inset-group">
      <view class="empty-icon">👤</view>
      <view class="empty-title">暂无联系人</view>
      <view class="empty-desc">点击底部 + 添加联系人</view>
    </view>
  </block>

  <block wx:else>
    <view class="inset-group swipe-list">
      <view
        class="swipe-row-shell {{item.deleteVisible ? 'delete-visible' : ''}} {{item.exiting ? 'exiting' : ''}}"
        wx:for="{{items}}"
        wx:key="id"
      >
        <view class="swipe-actions">
          <button
            class="swipe-delete"
            data-id="{{item.id}}"
            bindtap="onDeleteTap"
            loading="{{item.deleting}}"
          >
            删除
          </button>
        </view>
        <view
          class="swipe-row-content contact-swipe-content {{item.swiping ? 'swiping' : ''}} {{item.pressing ? 'row-pressed' : ''}}"
          style="transform: translateX({{item.swipeX}}px);"
        >
          <view class="avatar" style="background: {{item.avatarColor}};">{{item.initial}}</view>
          <view
            class="swipe-row-main"
            data-id="{{item.id}}"
            bindtouchstart="onRowTouchStart"
            bindtouchmove="onSwipeMove"
            bindtouchend="onRowTouchEnd"
            bindtouchcancel="onRowTouchEnd"
          >
            <view class="cell-body compact">
              <view class="cell-title">{{item.displayName}}</view>
              <view wx:if="{{item.subtitle}}" class="cell-subline">{{item.subtitle}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

</view>
