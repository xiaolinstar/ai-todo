<view class="page create-page">
  <view wx:if="{{loading}}" class="meta">加载中…</view>
  <block wx:else>
    <view class="group-header">日历详情</view>
    <view class="form-group">
      <view class="form-row stack title-edit-row">
        <text class="form-label">标题</text>
        <textarea class="form-title-textarea" style="height: {{titleTextareaHeight}}rpx;" placeholder="必填，最多 80 字" maxlength="80" value="{{title}}" bindinput="onTitleInput" />
      </view>
      <view class="form-row">
        <text class="form-label">开始</text>
        <view class="datetime-inline">
          <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
            <view class="picker-pill">{{startDate}}</view>
          </picker>
          <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
            <view class="picker-pill">{{startTime}}</view>
          </picker>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">结束时间</text>
        <switch checked="{{hasEnd}}" bindchange="onEndToggle" color="{{switchColor}}" />
      </view>
      <view wx:if="{{hasEnd}}" class="form-row">
        <text class="form-label">结束</text>
        <view class="datetime-inline">
          <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
            <view class="picker-pill">{{endDate}}</view>
          </picker>
          <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
            <view class="picker-pill">{{endTime}}</view>
          </picker>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">地点</text>
        <input class="form-input" placeholder="可选" value="{{location}}" bindinput="onLocationInput" />
      </view>
      <view class="form-row" bindtap="toggleDescription">
        <text class="form-label">描述</text>
        <text class="form-value muted">{{description ? '已填写' : '添加'}}</text>
        <view class="form-disclosure {{descriptionExpanded ? 'expanded' : ''}}"></view>
      </view>
      <view wx:if="{{descriptionExpanded}}" class="form-row stack">
        <textarea class="form-textarea" placeholder="可选" value="{{description}}" maxlength="1000" auto-height bindinput="onDescriptionInput" />
      </view>
      <view class="form-row">
        <text class="form-label">联系人</text>
        <button class="todo-button todo-button-ghost todo-button-sm pick-inline contact-picker-button" size="mini" hover-class="todo-button-hover" bindtap="pickContact">
          {{contactLabel}}
        </button>
      </view>
      <view wx:if="{{selectedContacts.length > 0}}" class="form-row">
        <text class="form-label"></text>
        <text class="chip-clear link-text" bindtap="clearContact">{{selectedContacts.length > 1 ? '移除全部联系人' : '移除联系人'}}</text>
      </view>
    </view>

    <button class="todo-button todo-button-primary submit" loading="{{submitting}}" hover-class="todo-button-hover" bindtap="onSubmit">
      保存日程
    </button>
  </block>
</view>
