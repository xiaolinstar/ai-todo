<view class="mine-subpage agent-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <view class="subpage-section">
        <view class="group-header">操作</view>
        <view class="inset-group subpage-group">
          <view class="subpage-cell pressable" hover-class="list-cell-hover" bindtap="onCreateToken">
            <view class="subpage-cell-main">
              <text class="subpage-label">{{quickCreating ? '创建中…' : '新建令牌'}}</text>
              <text class="subpage-meta">选择用途即可快速创建，也可自定义名称</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
          <view class="subpage-cell pressable" hover-class="list-cell-hover" bindtap="onOpenHelp">
            <view class="subpage-cell-main">
              <text class="subpage-label">CLI 配置方法</text>
              <text class="subpage-meta">复制登录命令后在电脑终端执行</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
        </view>
      </view>

      <view class="subpage-section">
        <view class="group-header">有效令牌 · {{activePatCount}}</view>
        <view class="inset-group subpage-group">
          <view wx:if="{{patLoading}}" class="subpage-cell">
            <text class="subpage-meta">加载中…</text>
          </view>
          <view wx:elif="{{activePatItems.length === 0}}" class="subpage-cell pressable" hover-class="list-cell-hover" bindtap="onCreateToken">
            <view class="subpage-cell-main">
              <text class="subpage-label">暂无有效令牌</text>
              <text class="subpage-meta">点此处或上方「新建令牌」连接电脑端工具</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
          <view
            wx:for="{{activePatItems}}"
            wx:key="id"
            class="subpage-cell pressable"
            hover-class="list-cell-hover"
            bindtap="onOpenDetail"
            data-id="{{item.id}}"
          >
            <view class="subpage-cell-main">
              <text class="subpage-label">{{item.name}}</text>
              <text class="subpage-meta">{{item.tokenHint}} · 到期 {{item.expiresAt}}</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
        </view>
      </view>

      <view wx:if="{{inactivePatCount > 0}}" class="subpage-section">
        <view class="group-header">已失效令牌 · {{inactivePatCount}}</view>
        <view class="inset-group subpage-group">
          <view class="subpage-cell pressable" hover-class="list-cell-hover" bindtap="onToggleInactive">
            <view class="subpage-cell-main">
              <text class="subpage-label">{{showInactive ? '收起列表' : '查看已失效令牌'}}</text>
            </view>
            <text class="subpage-chevron">{{showInactive ? '⌃' : '⌄'}}</text>
          </view>
          <block wx:if="{{showInactive}}">
            <view
              wx:for="{{inactivePatItems}}"
              wx:key="id"
              class="subpage-cell pressable inactive"
              hover-class="list-cell-hover"
              bindtap="onOpenDetail"
              data-id="{{item.id}}"
            >
              <view class="subpage-cell-main">
                <text class="subpage-label">{{item.name}}</text>
                <text class="subpage-meta">{{item.tokenHint}} · 到期 {{item.expiresAt}}</text>
              </view>
              <text class="subpage-chevron">›</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
