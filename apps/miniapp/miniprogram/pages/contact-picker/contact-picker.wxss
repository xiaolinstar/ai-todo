.picker-page {
  padding-top: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: var(--todo-surface-muted);
  font-size: 28rpx;
}

.search-btn {
  width: auto !important;
  min-height: 64rpx !important;
  padding: 0 24rpx !important;
  font-size: 26rpx !important;
}

.hint {
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.empty-card {
  padding: 48rpx 32rpx;
}

.contact-item {
  padding: 28rpx 32rpx;
}

.contact-name {
  color: var(--todo-text-primary);
  font-size: 30rpx;
  font-weight: 600;
}