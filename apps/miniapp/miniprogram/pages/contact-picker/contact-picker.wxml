<view class="page picker-page">
  <view class="search-group">
    <view class="search-wrap">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜索联系人"
        value="{{query}}"
        bindinput="onQueryInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <text wx:if="{{query}}" class="link-text" bindtap="onClearSearch">清除</text>
    </view>
  </view>

  <view class="form-hint">点击联系人即可选择并返回</view>

  <view wx:if="{{loading && !loaded}}" class="loading-state">
    <view class="meta">加载中…</view>
  </view>
  <view wx:elif="{{error}}" class="error-banner">{{error}}</view>

  <block wx:elif="{{items.length === 0}}">
    <view class="empty-state inset-group">
      <view class="empty-title">未找到联系人</view>
      <view class="empty-desc">请先在通讯录中添加联系人</view>
    </view>
  </block>

  <block wx:else>
    <view class="inset-group">
      <view
        class="list-cell contact-row-inner"
        wx:for="{{items}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onSelect"
        hover-class="list-cell-hover"
      >
        <view class="avatar" style="background: {{item.avatarColor}};">{{item.initial}}</view>
        <view class="cell-body">
          <view class="cell-title">{{item.displayName}}</view>
          <view wx:if="{{item.subtitle}}" class="cell-meta">{{item.subtitle}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
