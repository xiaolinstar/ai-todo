<view class="mine-subpage tag-detail-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <view wx:if="{{loading}}" class="subpage-hint">加载中…</view>
      <block wx:else>
        <view class="tag-preview">
          <text class="tag-preview-dot" style="background: {{color}};"></text>
          <text class="tag-preview-name">{{name || '未命名标签'}}</text>
        </view>

        <view class="group-header">基础信息</view>
        <view class="inset-group subpage-group">
          <view class="subpage-cell">
            <view class="subpage-cell-main">
              <text class="subpage-label">名称</text>
              <input class="tag-name-input" maxlength="32" value="{{name}}" bindinput="onNameInput" confirm-type="done" />
            </view>
          </view>
          <view class="subpage-cell">
            <text class="subpage-label">使用中</text>
            <text class="subpage-value">{{usageCount}} 个提醒</text>
          </view>
        </view>

        <view class="group-header">颜色</view>
        <view class="inset-group palette-card">
          <view class="palette-grid">
            <view
              wx:for="{{palette}}"
              wx:key="*this"
              class="color-choice {{color === item ? 'selected' : ''}}"
              style="background: {{item}};"
              data-color="{{item}}"
              bindtap="onColorTap"
              hover-class="pressable-active"
            >
              <text wx:if="{{color === item}}" class="color-check">✓</text>
            </view>
          </view>
        </view>

        <button class="todo-button todo-button-primary save-button" loading="{{saving}}" bindtap="onSave">保存</button>
        <button class="delete-button" loading="{{deleting}}" bindtap="onDelete">删除标签</button>
      </block>
    </view>
  </scroll-view>
</view>
