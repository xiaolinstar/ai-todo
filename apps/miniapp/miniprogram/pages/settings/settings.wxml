<view class="page settings-page">
  <view class="card section-inner">
    <view class="section-title">连接</view>
    <view class="field">
      <view class="field-label">API 地址</view>
      <input class="input-field" placeholder="http://127.0.0.1:3100" value="{{apiUrl}}" bindinput="onApiUrlInput" />
      <view class="meta help">本地默认 127.0.0.1:3100；真机请改为局域网 IP</view>
    </view>
    <view class="field">
      <view class="field-label">Personal Access Token（可选）</view>
      <input class="input-field" password placeholder="aitodo_xxx" value="{{token}}" bindinput="onTokenInput" />
      <view class="meta help">留空可使用 dev 旁路（AI_TODO_ALLOW_DEV_AUTH=true）</view>
    </view>
    <button class="todo-button todo-button-primary" hover-class="todo-button-hover" bindtap="onSave">保存</button>
  </view>

  <view class="card section-inner">
    <view class="section-title">账号</view>
    <view wx:if="{{userName}}" class="user-block">
      <view class="user-name">{{userName}}</view>
      <view class="meta">{{userId}} · {{timezone}}</view>
    </view>
    <view wx:else class="meta">尚未验证连接</view>
    <view class="action-row">
      <button class="todo-button todo-button-secondary action-btn" size="mini" loading="{{testing}}" hover-class="todo-button-hover" bindtap="onTest">测试连接</button>
      <button class="todo-button todo-button-secondary action-btn" size="mini" loading="{{issuing}}" hover-class="todo-button-hover" bindtap="onIssuePat">签发 PAT</button>
      <button class="todo-button todo-button-secondary action-btn" size="mini" hover-class="todo-button-hover" bindtap="onClearToken">清除 Token</button>
    </view>
  </view>

  <view class="card section-inner tips">
    <view class="section-title">开发提示</view>
    <view class="meta tip">1. 开发者工具 → 详情 → 勾选「不校验合法域名」</view>
    <view class="meta tip">2. 终端运行 pnpm dev:api</view>
    <view class="meta tip">3. 规范见 docs/miniapp-conventions.md</view>
  </view>
</view>
