<view class="mine-subpage about-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <view class="group-header">版本</view>
      <view class="inset-group subpage-group">
        <view class="subpage-cell">
          <view class="subpage-cell-main">
            <text class="subpage-label">小程序版本</text>
            <text class="subpage-meta">上传体验版时请填写相同版本号</text>
          </view>
          <text class="subpage-value">{{miniappVersion}}</text>
        </view>
        <view class="subpage-cell">
          <text class="subpage-label">运行环境</text>
          <text class="subpage-value">{{envLabel}}</text>
        </view>
        <view class="subpage-cell stack">
          <view class="subpage-cell-main">
            <text class="subpage-label">API 地址</text>
            <text class="subpage-meta">{{apiUrl}}</text>
          </view>
        </view>
        <view class="subpage-cell">
          <text class="subpage-label">API 服务</text>
          <text class="subpage-value">{{healthSummary}}</text>
        </view>
      </view>

      <view wx:if="{{loggedIn}}" class="subpage-section">
        <view class="group-header">账户</view>
        <view class="inset-group subpage-group">
          <view class="subpage-cell pressable" hover-class="list-cell-hover" bindtap="onCopyUserId">
            <view class="subpage-cell-main">
              <text class="subpage-label">用户 ID</text>
              <text class="subpage-meta">供 CLI 或反馈问题时引用，点击复制</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
        </view>
      </view>

      <view class="subpage-section">
        <view class="group-header">说明</view>
        <view class="inset-group subpage-group">
          <view class="subpage-cell stack">
            <view class="subpage-cell-main">
              <text class="subpage-label">数据范围</text>
              <text class="subpage-meta">仅管理应用内提醒、日历与联系人</text>
            </view>
          </view>
          <view class="subpage-cell stack">
            <view class="subpage-cell-main">
              <text class="subpage-label">CLI 使用</text>
              <text class="subpage-meta">创建访问令牌后写入 ~/.ai-todo/settings.json</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
