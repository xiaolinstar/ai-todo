<view class="mine-subpage content-prefs-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <text wx:if="{{loading}}" class="subpage-hint">加载中…</text>
      <block wx:else>
        <view class="subpage-section">
          <view class="group-header">日历</view>
          <view class="inset-group subpage-group">
            <view class="subpage-cell">
              <view class="subpage-cell-main">
                <text class="subpage-label">新建日程默认带结束时间</text>
              </view>
              <switch
                checked="{{defaultHasEnd}}"
                disabled="{{savingCalendar}}"
                bindchange="onDefaultHasEndChange"
                color="{{switchColor}}"
              />
            </view>
            <view wx:if="{{defaultHasEnd}}" class="subpage-cell">
              <view class="subpage-cell-main">
                <text class="subpage-label">默认时长</text>
              </view>
              <picker
                mode="selector"
                range="{{durationLabels}}"
                value="{{durationIndex}}"
                disabled="{{savingCalendar}}"
                bindchange="onDurationChange"
              >
                <view class="duration-picker">{{durationLabels[durationIndex]}}</view>
              </picker>
            </view>
            <view class="subpage-cell">
              <view class="subpage-cell-main">
                <text class="subpage-label">打开日历时选中今天</text>
              </view>
              <switch
                checked="{{selectTodayOnOpen}}"
                disabled="{{savingCalendar}}"
                bindchange="onSelectTodayChange"
                color="{{switchColor}}"
              />
            </view>
          </view>
        </view>

        <view class="subpage-section">
          <view class="group-header">提醒</view>
          <view class="inset-group subpage-group">
            <view class="subpage-cell">
              <view class="subpage-cell-main">
                <text class="subpage-label">列表显示标签</text>
                <text class="subpage-meta">关闭后仅保留标签搜索与编辑能力</text>
              </view>
              <switch
                checked="{{showTagsInList}}"
                disabled="{{savingReminders}}"
                bindchange="onShowTagsInListChange"
                color="{{switchColor}}"
              />
            </view>
          </view>
        </view>

        <view class="subpage-section">
          <view class="group-header">通讯录</view>
          <view class="inset-group subpage-group">
            <view class="subpage-cell">
              <view class="subpage-cell-main">
                <text class="subpage-label">列表排序</text>
              </view>
              <picker
                mode="selector"
                range="{{sortLabels}}"
                value="{{sortIndex}}"
                disabled="{{savingContacts}}"
                bindchange="onSortChange"
              >
                <view class="duration-picker">{{sortLabels[sortIndex]}}</view>
              </picker>
            </view>
            <view class="subpage-cell">
              <view class="subpage-cell-main">
                <text class="subpage-label">列表显示用户名</text>
                <text class="subpage-meta">handle，便于与平台用户对应</text>
              </view>
              <switch
                checked="{{showHandleInList}}"
                disabled="{{savingContacts}}"
                bindchange="onShowHandleChange"
                color="{{switchColor}}"
              />
            </view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
