<view class="mine-subpage security-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <view class="inset-group subpage-group">
        <view class="subpage-cell stack">
          <view class="subpage-cell-main">
            <text class="subpage-label">登录方式</text>
            <text class="subpage-meta">微信登录</text>
          </view>
        </view>
        <view class="subpage-cell stack pressable" hover-class="list-cell-hover" bindtap="onOpenAgent">
          <view class="subpage-cell-main">
            <text class="subpage-label">访问令牌（PAT）</text>
            <text class="subpage-meta">供电脑端 CLI / Agent 访问你的数据，请妥善保管，勿分享给他人。</text>
          </view>
          <text class="subpage-chevron">›</text>
        </view>
        <view class="subpage-cell stack">
          <view class="subpage-cell-main">
            <text class="subpage-label">数据范围</text>
            <text class="subpage-meta">应用内提醒、日历与联系人</text>
          </view>
        </view>
      </view>

      <view class="subpage-section">
        <view class="inset-group subpage-group">
          <view class="subpage-cell stack pressable" hover-class="list-cell-hover" bindtap="onLogout">
            <view class="subpage-cell-main">
              <text class="subpage-label danger">退出登录</text>
              <text class="subpage-meta">退出后需重新微信登录</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
