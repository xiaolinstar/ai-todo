<view class="mine-subpage settings-timezone-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <view class="group-header">账户时区</view>
      <view class="inset-group subpage-group">
        <picker mode="selector" range="{{timezoneLabels}}" value="{{timezoneIndex}}" disabled="{{loading || saving}}" bindchange="onTimezoneChange">
          <view class="subpage-cell picker-row">
            <view class="subpage-cell-main">
              <text class="subpage-label">时区</text>
              <text class="subpage-meta">提醒和日历按此时区显示</text>
            </view>
            <text class="subpage-value">{{timezoneLabel}}</text>
            <view class="form-disclosure"></view>
          </view>
        </picker>
        <view class="subpage-cell clock-row">
          <text class="subpage-label">当前时刻</text>
          <text class="subpage-value emphasis">{{nowClock}}</text>
        </view>
        <view class="subpage-cell clock-row">
          <text class="subpage-label">账户今天</text>
          <text class="subpage-value">{{accountToday}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
