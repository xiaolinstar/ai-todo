<view class="mine-page">
  <scroll-view scroll-y class="mine-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-scroll-inner">
      <view
        class="profile-card inset-group pressable"
        hover-class="pressable-active"
        bindtap="onProfileCardTap"
      >
        <view class="profile-inner">
          <view wx:if="{{avatarUrl && !avatarBroken}}" class="avatar avatar-lg avatar-image-wrap">
            <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
          </view>
          <view wx:else class="avatar avatar-lg" style="background: {{avatarColor}};">{{initial}}</view>
          <view class="profile-text">
            <view class="profile-name">{{userName || '未登录'}}</view>
            <view wx:if="{{loggedIn}}" class="profile-username username-display username-display--truncate">{{userUsername}}</view>
            <view wx:elif="{{profileSubtitle}}" class="profile-sub">{{profileSubtitle}}</view>
          </view>
          <text wx:if="{{loggedIn}}" class="chevron">›</text>
        </view>
      </view>

      <view wx:if="{{!loggedIn}}" class="login-block">
        <button
          class="todo-button todo-button-primary"
          hover-class="todo-button-hover"
          bindtap="onWechatLogin"
          loading="{{loggingIn}}"
          disabled="{{loggingIn}}"
        >
          {{loggingIn ? '登录中…' : '微信登录'}}
        </button>
      </view>

      <view
        class="menu-section"
        wx:for="{{menuSections}}"
        wx:key="id"
        wx:for-item="section"
      >
        <view class="group-header">{{section.title}}</view>
        <view class="inset-group menu-group">
          <view
            class="settings-cell pressable"
            wx:for="{{section.items}}"
            wx:key="id"
            wx:for-item="item"
            hover-class="list-cell-hover"
            bindtap="onMenuItemTap"
            data-section-id="{{section.id}}"
            data-item-id="{{item.id}}"
          >
            <text class="settings-label">{{item.label}}</text>
            <text class="chevron">›</text>
          </view>
        </view>
      </view>

    </view>
  </scroll-view>

  <view wx:if="{{showProfileSetup}}" class="profile-setup-mask">
    <view class="profile-setup-panel">
      <view class="profile-setup-title">确认微信资料</view>
      <view class="profile-setup-hint">选择微信头像和昵称，作为本小程序的账户信息。</view>
      <button class="setup-avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseSetupAvatar">
        <image wx:if="{{setupAvatarUrl}}" class="setup-avatar-image" src="{{setupAvatarUrl}}" mode="aspectFill" />
        <text wx:else>{{initial}}</text>
      </button>
      <input
        class="setup-name-input"
        type="nickname"
        placeholder="点击选择微信昵称"
        value="{{setupNameInput}}"
        bindinput="onSetupNameInput"
        bindblur="onSetupNameBlur"
      />
      <view class="profile-setup-actions">
        <view class="profile-setup-dismiss pressable" hover-class="list-cell-hover" bindtap="onCancelProfileSetup">暂不设置</view>
      </view>
    </view>
  </view>

  <privacy-authorization
    visible="{{showPrivacyAuthorization}}"
    bind:agree="onPrivacyAgree"
    bind:disagree="onPrivacyDisagree"
  />
</view>
