<view class="page page-with-tab mine-page">
  <view class="profile-card inset-group">
    <view class="profile-inner">
      <view class="avatar avatar-lg" style="background: {{avatarColor}};">{{initial}}</view>
      <view class="profile-text">
        <view class="profile-name">{{userName || '未连接'}}</view>
        <view wx:if="{{connected}}" class="cell-meta">{{userId}}</view>
        <view wx:if="{{connected}}" class="cell-meta">{{timezone}}</view>
        <view wx:else class="cell-meta">配置 API 后使用微信登录同步数据</view>
      </view>
      <view class="status-dot {{connected ? 'online' : ''}}"></view>
    </view>
  </view>

  <view wx:if="{{showDevControls}}" class="group-header">连接</view>
  <view wx:if="{{showDevControls}}" class="form-group">
    <view class="form-row stack">
      <text class="form-label">API 地址</text>
      <input class="form-input" placeholder="https://wodi.games" value="{{apiUrl}}" bindinput="onApiUrlInput" />
    </view>
    <view class="form-row stack">
      <text class="form-label">Access Token</text>
      <input class="form-input" password placeholder="aitodo_xxx（可选，开发用）" value="{{token}}" bindinput="onTokenInput" />
    </view>
  </view>
  <view wx:if="{{showDevControls}}" class="form-hint">开发环境：未配微信 AppID/Secret 时，「微信登录」会使用本地开发用户并签发 Token</view>
  <view wx:else class="form-hint">当前使用生产 API：{{apiUrl}}。Access Token 会在微信登录后自动保存。</view>
  <button class="todo-button todo-button-primary" hover-class="todo-button-hover" bindtap="onWechatLogin">{{loggingIn ? '登录中…' : '微信登录'}}</button>
  <button wx:if="{{showDevControls}}" class="todo-button todo-button-secondary" hover-class="todo-button-hover" bindtap="onSave">保存并连接</button>

  <view class="group-header">账号操作</view>
  <view class="inset-group action-group">
    <view class="settings-cell pressable" bindtap="onTestConnection" hover-class="list-cell-hover">
      <text class="settings-label">测试连接</text>
      <text class="settings-value">{{testing ? '检测中…' : (connected ? '已连接' : '未连接')}}</text>
    </view>
    <view wx:if="{{showDevControls}}" class="settings-cell pressable" bindtap="onIssuePat" hover-class="list-cell-hover">
      <text class="settings-label">签发 PAT（开发）</text>
      <text class="settings-value link-text">{{issuing ? '处理中…' : '创建'}}</text>
    </view>
    <view class="settings-cell pressable" bindtap="onClearToken" hover-class="list-cell-hover">
      <text class="settings-label danger">清除 Token</text>
    </view>
  </view>

  <view wx:if="{{showDevControls}}" class="group-header">开发提示</view>
  <view wx:if="{{showDevControls}}" class="inset-group tips-group">
    <view class="settings-cell">
      <text class="cell-meta">开发者工具 → 详情 → 勾选「不校验合法域名」</text>
    </view>
    <view class="settings-cell">
      <text class="cell-meta">服务端需配置 AI_TODO_WECHAT_APP_ID / SECRET</text>
    </view>
    <view class="settings-cell">
      <text class="cell-meta">本地 dev 可留空 Token 并使用 allow_dev_auth</text>
    </view>
  </view>
</view>
