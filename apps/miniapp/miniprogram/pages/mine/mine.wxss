.mine-page {
  padding-top: 8rpx;
}

.profile-card {
  margin-bottom: 32rpx;
}

.profile-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx 28rpx;
}

.profile-text {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: var(--todo-text-primary);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.status-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c7c7cc;
}

.status-dot.online {
  background: var(--todo-good);
}

.action-group .settings-cell + .settings-cell,
.tips-group .settings-cell + .settings-cell {
  border-top: var(--todo-separator);
}

.settings-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 24rpx 28rpx;
  background: var(--todo-surface);
}

.settings-label {
  color: var(--todo-text-primary);
  font-size: 30rpx;
}

.settings-label.danger {
  color: var(--todo-danger);
}

.settings-value {
  color: var(--todo-text-subtle);
  font-size: 28rpx;
}

.todo-button {
  margin-bottom: 32rpx;
}