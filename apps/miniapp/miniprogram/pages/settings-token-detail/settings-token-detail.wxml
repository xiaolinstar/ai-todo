<view class="mine-subpage token-detail-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <text wx:if="{{loading}}" class="subpage-hint">加载中…</text>

      <text wx:elif="{{!found}}" class="subpage-hint">未找到该访问令牌。</text>

      <block wx:else>
        <view class="inset-group subpage-group">
          <view class="subpage-cell">
            <view class="subpage-cell-main">
              <text class="subpage-label">{{name}}</text>
              <text class="subpage-meta">{{tokenHint}} · 到期 {{expiresAt}}</text>
            </view>
          </view>
          <view wx:if="{{!isActive}}" class="subpage-cell">
            <view class="subpage-cell-main">
              <text class="subpage-label">失效原因</text>
              <text class="subpage-meta">{{inactiveSummary}}</text>
            </view>
          </view>
        </view>

        <view class="subpage-section">
          <view class="inset-group subpage-group">
            <view class="subpage-cell pressable" hover-class="list-cell-hover" bindtap="onCopySettingsTemplate">
              <view class="subpage-cell-main">
                <text class="subpage-label">复制配置模板</text>
              </view>
              <text class="subpage-chevron">›</text>
            </view>
            <view
              wx:if="{{isActive}}"
              class="subpage-cell pressable"
              hover-class="list-cell-hover"
              bindtap="onRevoke"
            >
              <view class="subpage-cell-main">
                <text class="subpage-label danger">{{revoking ? '吊销中…' : '吊销此令牌'}}</text>
              </view>
              <text class="subpage-chevron">›</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
