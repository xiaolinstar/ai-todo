<view class="mine-subpage profile-settings-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <view class="group-header">账户资料</view>
      <view class="inset-group subpage-group profile-form">
        <view class="avatar-row">
          <text class="subpage-label">头像</text>
          <button class="profile-avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{avatarUrl}}" class="profile-avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
            <text wx:else>{{initial}}</text>
          </button>
        </view>
        <view class="subpage-cell">
          <text class="subpage-label">昵称</text>
          <input
            class="profile-input"
            type="nickname"
            placeholder="选择或输入昵称"
            value="{{displayName}}"
            bindinput="onNameInput"
            bindblur="onNameBlur"
            disabled="{{loading || saving}}"
          />
        </view>
        <view class="subpage-cell">
          <text class="subpage-label">用户名</text>
          <text class="username-display" selectable>{{userUsername}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <privacy-authorization
    visible="{{showPrivacyAuthorization}}"
    bind:agree="onPrivacyAgree"
    bind:disagree="onPrivacyDisagree"
  />
</view>
