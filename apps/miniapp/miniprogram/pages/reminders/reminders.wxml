<view class="page page-with-tab reminders-page">
  <view wx:if="{{error}}" class="error-banner">
    <text>{{error}}</text>
    <text class="link-text" bindtap="goMine">去配置</text>
  </view>

  <view class="large-title-wrap">
    <view class="large-title">提醒</view>
    <view class="large-subtitle">{{dateLabel}} {{weekdayLabel}}<text wx:if="{{timezone}}"> · {{timezone}}</text></view>
    <view class="summary-row" wx:if="{{loaded && !error}}">
      <view class="summary-chip">{{pendingCount}} 条未完成</view>
      <view wx:if="{{inProgressCount > 0}}" class="summary-chip">{{inProgressCount}} 条处理中</view>
      <view wx:if="{{overdueCount > 0}}" class="summary-chip warn">{{overdueCount}} 条已逾期</view>
    </view>
  </view>

  <view wx:if="{{loaded && !error}}" class="segmented segmented-3">
    <view
      class="segment pressable {{activeTab === 'pending' ? 'active' : ''}}"
      data-tab="pending"
      bindtap="onTabChange"
      hover-class="segment-press"
    >
      未完成
    </view>
    <view
      class="segment pressable {{activeTab === 'in_progress' ? 'active' : ''}}"
      data-tab="in_progress"
      bindtap="onTabChange"
      hover-class="segment-press"
    >
      处理中<text wx:if="{{inProgressCount > 0}}" class="segment-badge">{{inProgressCount}}</text>
    </view>
    <view
      class="segment pressable {{activeTab === 'completed' ? 'active' : ''}}"
      data-tab="completed"
      bindtap="onTabChange"
      hover-class="segment-press"
    >
      已完成<text wx:if="{{completedCount > 0}}" class="segment-badge">{{completedCount}}</text>
    </view>
  </view>

  <view wx:if="{{loading && !loaded}}" class="loading-state">
    <view class="meta">加载中…</view>
  </view>

  <block wx:elif="{{activeTab === 'pending'}}">
    <block wx:if="{{pending.length === 0}}">
      <view class="empty-state inset-group">
        <view class="empty-icon">☑︎</view>
        <view class="empty-title">暂无未完成提醒</view>
        <view class="empty-desc">点击底部中间 + 新建提醒</view>
      </view>
    </block>
    <block wx:else>
      <block wx:for="{{pendingGroups}}" wx:for-item="group" wx:key="key">
        <view class="group-header">{{group.title}}</view>
        <view class="inset-group reminder-list">
          <view
            class="swipe-shell reminder-row {{item.deleteVisible ? 'delete-visible' : ''}} {{item.completing ? 'completing' : ''}} {{item.exiting ? 'exiting' : ''}}"
            wx:for="{{group.items}}"
            wx:key="id"
          >
            <view class="swipe-actions">
              <button
                class="swipe-delete"
                data-id="{{item.id}}"
                bindtap="onDeleteTap"
                loading="{{item.deleting}}"
              >
                删除
              </button>
            </view>
            <view
              class="list-cell reminder-swipe-content {{item.swiping ? 'swiping' : ''}} {{item.pressing ? 'reminder-row-pressed' : ''}}"
              style="transform: translateX({{item.swipeX}}px);"
            >
              <view
                class="check-hit"
                data-id="{{item.id}}"
                catchtap="onComplete"
                hover-class="check-hit-hover"
                hover-stop-propagation
              >
                <view class="reminder-check {{item.completing ? 'checked popping' : ''}}">
                  <text wx:if="{{item.completing}}" class="check-mark">✓</text>
                </view>
              </view>
              <view
                class="reminder-row-main"
                data-id="{{item.id}}"
                bindtouchstart="onRowTouchStart"
                bindtouchmove="onSwipeMove"
                bindtouchend="onRowTouchEnd"
                bindtouchcancel="onRowTouchEnd"
              >
                <view class="cell-body compact">
                  <view class="title-line">
                    <view class="cell-title {{item.completing ? 'done' : ''}}">{{item.title}}</view>
                    <view wx:if="{{item.sourceLabel}}" class="source-badge">{{item.sourceLabel}}</view>
                  </view>
                  <view
                    wx:if="{{item.subline}}"
                    class="cell-subline {{item.isOverdue && !item.completing ? 'overdue' : ''}}"
                  >
                    {{item.subline}}
                  </view>
                </view>
                <text
                  wx:if="{{!item.completing}}"
                  class="status-action link-text"
                  data-id="{{item.id}}"
                  catchtap="onMarkInProgress"
                >
                  处理中
                </text>
              </view>
            </view>
          </view>
        </view>
      </block>
    </block>
  </block>

  <block wx:elif="{{activeTab === 'in_progress'}}">
    <block wx:if="{{inProgress.length === 0}}">
      <view class="empty-state inset-group">
        <view class="empty-icon">◎</view>
        <view class="empty-title">暂无处理中提醒</view>
        <view class="empty-desc">在未完成列表中可将事项标为处理中</view>
      </view>
    </block>
    <block wx:else>
      <block wx:for="{{inProgressGroups}}" wx:for-item="group" wx:key="key">
        <view class="group-header">{{group.title}}</view>
        <view class="inset-group reminder-list">
          <view
            class="swipe-shell reminder-row {{item.deleteVisible ? 'delete-visible' : ''}} {{item.completing ? 'completing' : ''}} {{item.exiting ? 'exiting' : ''}}"
            wx:for="{{group.items}}"
            wx:key="id"
          >
            <view class="swipe-actions">
              <button
                class="swipe-delete"
                data-id="{{item.id}}"
                bindtap="onDeleteTap"
                loading="{{item.deleting}}"
              >
                删除
              </button>
            </view>
            <view
              class="list-cell reminder-swipe-content {{item.swiping ? 'swiping' : ''}} {{item.pressing ? 'reminder-row-pressed' : ''}}"
              style="transform: translateX({{item.swipeX}}px);"
            >
              <view
                class="check-hit"
                data-id="{{item.id}}"
                catchtap="onComplete"
                hover-class="check-hit-hover"
                hover-stop-propagation
              >
                <view class="reminder-check {{item.completing ? 'checked popping' : ''}}">
                  <text wx:if="{{item.completing}}" class="check-mark">✓</text>
                </view>
              </view>
              <view
                class="reminder-row-main"
                data-id="{{item.id}}"
                bindtouchstart="onRowTouchStart"
                bindtouchmove="onSwipeMove"
                bindtouchend="onRowTouchEnd"
                bindtouchcancel="onRowTouchEnd"
              >
                <view class="cell-body compact">
                  <view class="title-line">
                    <view class="cell-title {{item.completing ? 'done' : ''}}">{{item.title}}</view>
                    <view wx:if="{{item.sourceLabel}}" class="source-badge">{{item.sourceLabel}}</view>
                  </view>
                  <view
                    wx:if="{{item.subline}}"
                    class="cell-subline {{item.isOverdue && !item.completing ? 'overdue' : ''}}"
                  >
                    {{item.subline}}
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </block>
  </block>

  <block wx:elif="{{activeTab === 'completed'}}">
    <block wx:if="{{completed.length === 0}}">
      <view class="empty-state inset-group">
        <view class="empty-icon">✓</view>
        <view class="empty-title">暂无已完成提醒</view>
        <view class="empty-desc">完成的提醒会出现在这里</view>
      </view>
    </block>
    <block wx:else>
      <view class="group-header">已完成</view>
      <view class="inset-group reminder-list">
        <view
          class="swipe-shell reminder-row {{item.deleteVisible ? 'delete-visible' : ''}} {{item.exiting ? 'exiting' : ''}}"
          wx:for="{{completed}}"
          wx:key="id"
        >
          <view class="swipe-actions">
            <button
              class="swipe-delete"
              data-id="{{item.id}}"
              bindtap="onDeleteTap"
              loading="{{item.deleting}}"
            >
              删除
            </button>
          </view>
          <view
            class="list-cell reminder-swipe-content {{item.swiping ? 'swiping' : ''}} {{item.pressing ? 'reminder-row-pressed' : ''}}"
            style="transform: translateX({{item.swipeX}}px);"
          >
            <view class="check-hit check-hit-static">
              <view class="reminder-check checked static">
                <text class="check-mark">✓</text>
              </view>
            </view>
            <view
              class="reminder-row-main"
              data-id="{{item.id}}"
              bindtouchstart="onRowTouchStart"
              bindtouchmove="onSwipeMove"
              bindtouchend="onRowTouchEnd"
              bindtouchcancel="onRowTouchEnd"
            >
              <view class="cell-body compact">
                <view class="title-line">
                  <view class="cell-title done">{{item.title}}</view>
                  <view wx:if="{{item.sourceLabel}}" class="source-badge muted">{{item.sourceLabel}}</view>
                </view>
                <view wx:if="{{item.subline}}" class="cell-subline">{{item.subline}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>
