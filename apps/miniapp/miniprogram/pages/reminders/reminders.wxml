<view class="page page-with-tab reminders-page">
  <view wx:if="{{error}}" class="error-banner">
    <text>{{error}}</text>
    <text class="link-text" bindtap="goMine">去配置</text>
  </view>

  <view class="large-title-wrap">
    <view class="large-title">提醒</view>
    <view class="large-subtitle">{{dateLabel}} {{weekdayLabel}}<text wx:if="{{timezone}}"> · {{timezone}}</text></view>
    <view class="summary-row" wx:if="{{loaded && !error}}">
      <view class="summary-chip">{{pendingCount}} 条未完成</view>
      <view wx:if="{{overdueCount > 0}}" class="summary-chip warn">{{overdueCount}} 条已逾期</view>
    </view>
  </view>

  <view wx:if="{{loaded && !error}}" class="segmented">
    <view
      class="segment pressable {{activeTab === 'pending' ? 'active' : ''}}"
      data-tab="pending"
      bindtap="onTabChange"
      hover-class="segment-press"
    >
      未完成
    </view>
    <view
      class="segment pressable {{activeTab === 'completed' ? 'active' : ''}}"
      data-tab="completed"
      bindtap="onTabChange"
      hover-class="segment-press"
    >
      已完成<text wx:if="{{completedCount > 0}}" class="segment-badge">{{completedCount}}</text>
    </view>
  </view>

  <view wx:if="{{loading && !loaded}}" class="loading-state">
    <view class="meta">加载中…</view>
  </view>

  <block wx:elif="{{activeTab === 'pending'}}">
    <block wx:if="{{pending.length === 0}}">
      <view class="empty-state inset-group">
        <view class="empty-icon">☑︎</view>
        <view class="empty-title">今天没有提醒</view>
        <view class="empty-desc">点击底部中间 + 新建提醒，完成后会短暂停留再收起</view>
      </view>
    </block>
    <block wx:else>
      <view class="group-header">今天</view>
      <view class="inset-group reminder-list">
        <view
          class="swipe-shell reminder-row {{item.completing ? 'completing' : ''}} {{item.exiting ? 'exiting' : ''}}"
          wx:for="{{pending}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtouchstart="onSwipeStart"
          bindtouchmove="onSwipeMove"
          bindtouchend="onSwipeEnd"
          bindtouchcancel="onSwipeEnd"
        >
          <view class="swipe-actions">
            <button
              class="swipe-delete"
              data-id="{{item.id}}"
              bindtap="onDeleteTap"
              loading="{{item.deleting}}"
            >
              删除
            </button>
          </view>
          <view
            class="list-cell reminder-swipe-content {{item.swiping ? 'swiping' : ''}}"
            style="transform: translateX({{item.swipeX}}px);"
          >
            <view
              class="check-hit"
              data-id="{{item.id}}"
              bindtap="onComplete"
              hover-class="check-hit-hover"
            >
              <view class="reminder-check {{item.completing ? 'checked popping' : ''}}">
                <text wx:if="{{item.completing}}" class="check-mark">✓</text>
              </view>
            </view>
            <view class="cell-body compact">
              <view class="cell-title {{item.completing ? 'done' : ''}}">{{item.title}}</view>
              <view
                wx:if="{{item.subline}}"
                class="cell-subline {{item.isOverdue && !item.completing ? 'overdue' : ''}}"
              >
                {{item.subline}}
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>

  <block wx:elif="{{activeTab === 'completed'}}">
    <block wx:if="{{completed.length === 0}}">
      <view class="empty-state inset-group">
        <view class="empty-icon">✓</view>
        <view class="empty-title">暂无已完成提醒</view>
        <view class="empty-desc">完成的提醒会出现在这里</view>
      </view>
    </block>
    <block wx:else>
      <view class="group-header">已完成</view>
      <view class="inset-group reminder-list">
        <view
          class="swipe-shell reminder-row {{item.exiting ? 'exiting' : ''}}"
          wx:for="{{completed}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtouchstart="onSwipeStart"
          bindtouchmove="onSwipeMove"
          bindtouchend="onSwipeEnd"
          bindtouchcancel="onSwipeEnd"
        >
          <view class="swipe-actions">
            <button
              class="swipe-delete"
              data-id="{{item.id}}"
              bindtap="onDeleteTap"
              loading="{{item.deleting}}"
            >
              删除
            </button>
          </view>
          <view
            class="list-cell reminder-swipe-content {{item.swiping ? 'swiping' : ''}}"
            style="transform: translateX({{item.swipeX}}px);"
          >
            <view class="check-hit">
              <view class="reminder-check checked static">
                <text class="check-mark">✓</text>
              </view>
            </view>
            <view class="cell-body compact">
              <view class="cell-title done">{{item.title}}</view>
              <view wx:if="{{item.subline}}" class="cell-subline">{{item.subline}}</view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>
</view>
