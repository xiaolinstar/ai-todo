<view class="mine-subpage notification-settings-page">
  <scroll-view scroll-y class="mine-subpage-scroll" enhanced show-scrollbar="{{false}}">
    <view class="mine-subpage-inner">
      <text wx:if="{{loading}}" class="subpage-hint">加载中…</text>
      <block wx:else>
        <view class="group-header">微信通知</view>
        <view class="inset-group subpage-group">
          <view class="subpage-cell">
            <view class="subpage-cell-main">
              <text class="subpage-label">微信提醒</text>
              <text class="subpage-meta" wx:if="{{wechatEnabled}}">创建或修改提醒、日历时自动请求微信提醒</text>
              <text class="subpage-meta" wx:else>关闭后，新建或编辑事项不再请求微信提醒授权；此前已授权的提醒仍可能送达。</text>
            </view>
            <switch
              checked="{{wechatEnabled}}"
              disabled="{{saving}}"
              bindchange="onWechatEnabledChange"
              color="{{switchColor}}"
            />
          </view>
          <view
            class="subpage-cell pressable"
            hover-class="list-cell-hover"
            bindtap="onOpenQuietHours"
          >
            <view class="subpage-cell-main">
              <text class="subpage-label">免打扰时段</text>
              <text class="subpage-meta">该时段内不发送微信提醒</text>
            </view>
            <text class="subpage-value">{{quietHoursLabel}}</text>
            <text class="subpage-chevron">›</text>
          </view>
          <view wx:if="{{!templateConfigured}}" class="subpage-cell stack">
            <view class="subpage-cell-main">
              <text class="subpage-label">模板状态</text>
              <text class="subpage-meta">服务端尚未配置微信提醒模板，开关保存后仍无法推送。</text>
            </view>
          </view>
        </view>

        <view class="group-header">记录</view>
        <view class="inset-group subpage-group">
          <view
            class="subpage-cell pressable"
            hover-class="list-cell-hover"
            bindtap="onOpenDelivery"
          >
            <view class="subpage-cell-main">
              <text class="subpage-label">最近送达</text>
              <text class="subpage-meta">查看微信提醒推送记录</text>
            </view>
            <text class="subpage-chevron">›</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
