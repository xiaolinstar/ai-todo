<view class="page create-page">
  <view wx:if="{{loading}}" class="meta">加载中…</view>
  <block wx:else>
    <view class="group-header">提醒详情</view>
    <view class="form-group">
      <view class="form-row stack title-edit-row">
        <text class="form-label">标题</text>
        <textarea class="form-title-textarea" style="height: {{titleTextareaHeight}}rpx;" placeholder="必填，最多 80 字" maxlength="80" value="{{title}}" bindinput="onTitleInput" />
      </view>
      <view class="form-row" bindtap="toggleNotes">
        <text class="form-label">备注</text>
        <text class="form-value muted">{{notes ? '已填写' : '添加'}}</text>
        <view class="form-disclosure {{notesExpanded ? 'expanded' : ''}}"></view>
      </view>
      <view wx:if="{{notesExpanded}}" class="form-row stack">
        <textarea class="form-textarea" placeholder="可选" value="{{notes}}" maxlength="1000" auto-height bindinput="onNotesInput" />
      </view>
      <view wx:if="{{sourceLabel}}" class="form-row">
        <text class="form-label">来源</text>
        <text class="form-value muted">{{sourceLabel}}</text>
      </view>
      <view class="form-row stack">
        <text class="form-label">状态</text>
        <view class="segmented segmented-3 status-segment">
          <view
            class="segment pressable {{status === 'pending' ? 'active' : ''}}"
            data-status="pending"
            bindtap="onStatusChange"
          >
            未完成
          </view>
          <view
            class="segment pressable {{status === 'in_progress' ? 'active' : ''}}"
            data-status="in_progress"
            bindtap="onStatusChange"
          >
            处理中
          </view>
          <view
            class="segment pressable {{status === 'completed' ? 'active' : ''}}"
            data-status="completed"
            bindtap="onStatusChange"
          >
            已完成
          </view>
        </view>
      </view>
      <view wx:if="{{!isCompleted}}" class="form-row">
        <text class="form-label">截止时间</text>
        <switch checked="{{hasDue}}" bindchange="onDueToggle" color="{{switchColor}}" />
      </view>
      <view wx:if="{{!isCompleted && hasDue}}" class="form-row">
        <text class="form-label">截止</text>
        <view class="datetime-inline">
          <picker mode="date" value="{{dueDate}}" bindchange="onDateChange">
            <view class="picker-pill">{{dueDate}}</view>
          </picker>
          <picker mode="time" value="{{dueTime}}" bindchange="onTimeChange">
            <view class="picker-pill">{{dueTime}}</view>
          </picker>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">联系人</text>
        <button class="todo-button todo-button-ghost todo-button-sm pick-inline contact-picker-button" size="mini" hover-class="todo-button-hover" bindtap="pickContact">
          {{contactLabel}}
        </button>
      </view>
      <view wx:if="{{selectedContacts.length > 0}}" class="form-row">
        <text class="form-label"></text>
        <text class="chip-clear link-text" bindtap="clearContact">{{selectedContacts.length > 1 ? '移除全部联系人' : '移除联系人'}}</text>
      </view>
    </view>

    <button class="todo-button todo-button-primary submit" loading="{{submitting}}" hover-class="todo-button-hover" bindtap="onSubmit">
      保存提醒
    </button>
  </block>
</view>
