# Copy to ci.env (gitignored) and fill in paths, then from apps/miniapp:
#   set -a && source ci.env && set +a
#   pnpm preview

# Upload private key from 微信公众平台 → 开发管理 → 小程序代码上传
WECHAT_CI_PRIVATE_KEY_PATH=/path/to/private.wxYOUR_APPID.key

# Optional overrides (default: read appid from project.private.config.json)
# WECHAT_CI_APPID=wxYOUR_APPID

# CI robot slot 1-30 (default 1)
# WECHAT_CI_ROBOT=1

# Default preview/upload remark
# WECHAT_CI_DESC=local debug preview
