# =============================================================================
# GitHub Actions · Variables（非敏感）
# =============================================================================
#
# 用途：CD workflow 的部署目标与探活配置（L2 Variables）。
# 本地路径：~/.config/xiaolinstar/ai-todo/github/<environment>/variables.env
# 同步命令：sync.sh env sync-github --project ai-todo --environment <environment>
#
# 说明：
#   · 所有 GitHub Environment 使用**相同键名**；仅「环境标识」与本文件末尾示例值不同
#   · [必填] sync 前必须有值；[可选] 可留空（空值不会推送）；[k8s] 仅 DEPLOY_BACKEND=k8s 时生效
#   · 业务密钥（DB、微信等）在 VPS L3，不在此文件
#   · production-k8s = CD 部署面（111 · k3s）；K8s overlay / AI_TODO_ENVIRONMENT 仍为 production
#
# --- 环境标识 [必填] ---
GITHUB_REPOSITORY=xiaolinstar/ai-todo
GITHUB_ENVIRONMENT=production-k8s

# --- SSH 目标 [必填] ---
DEPLOY_HOST=111.229.38.208
DEPLOY_USER=ubuntu
DEPLOY_PORT=22
# DEPLOY_PATH=/home/ubuntu/AgentProjects/ai-todo  （GitHub Variable 不支持 $HOME 展开，请写绝对路径）
DEPLOY_PATH=/home/ubuntu/AgentProjects/ai-todo

# --- CD 探活 [必填] ---
CD_PUBLIC_API_URL=https://xingxiaolin.cn

# --- CD 探活 [可选] ---
# Gateway 切流前的本机探活（K8s NodePort 等）；Compose 可留空
CD_LOCAL_HEALTH_URL=http://127.0.0.1:30082

# --- 部署后端 [必填] compose | k8s ---
DEPLOY_BACKEND=k8s

# --- Kubernetes [k8s] DEPLOY_BACKEND=k8s 时填写；Compose 可保留默认 ---
K8S_OVERLAY=apps/api/deploy/k8s/overlays/production
K8S_NAMESPACE=ai-todo
K8S_REGISTRY_MIRROR=ghcr.nju.edu.cn

# --- GHCR [可选] 私有镜像拉取 ---
# GHCR_DEPLOY_USER=
