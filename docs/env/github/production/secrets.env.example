# GitHub Actions · Secrets（敏感）
# Environment: production
#
# Copy to: ~/.config/xiaolinstar/ai-todo/github/production/secrets.env
# Sync:    sync.sh env sync-github --project ai-todo --environment production

# SSH：本地用文件路径，sync 脚本读取后 gh secret set DEPLOY_SSH_KEY
DEPLOY_SSH_KEY_FILE=$HOME/.ssh/ai_todo_deploy
