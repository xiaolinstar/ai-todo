# GitHub Environment secrets template for ai-todo.
#
# Use this as a checklist for GitHub Settings > Environments:
#   production
#   staging
#
# Do not commit real values. Set secrets through GitHub UI or gh CLI.

# SSH target for CD.
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PORT=22
DEPLOY_PATH=

# Choose one SSH auth method. Prefer DEPLOY_SSH_KEY for CD.
DEPLOY_SSH_KEY=
# DEPLOY_PASSWORD=

# Public API base URL used by CD post-deploy verify and Monitor workflow.
CD_PUBLIC_API_URL=

# Optional authenticated smoke checks.
# CD_SMOKE_PAT=

# Optional GHCR pull auth. Required for private GHCR packages; optional for public packages.
# GHCR_DEPLOY_USER=
# GHCR_DEPLOY_TOKEN=

# Optional alert webhook. scripts/ops/check-alerts.py POSTs JSON here on failure.
# ALERT_WEBHOOK_URL=
