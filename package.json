{
  "name": "ai-todo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev:api": "apps/api/.venv/bin/python -m ai_todo_api",
    "cleanup:local-tokens": "apps/api/.venv/bin/python apps/api/scripts/cleanup_local_tokens.py",
    "dev:cli": "pnpm --filter @ai-todo/cli build && pnpm --filter @ai-todo/cli dev",
    "cli": "pnpm --filter @ai-todo/cli build && node apps/cli/dist/index.js",
    "test:api": "pnpm --filter @ai-todo/cli build && cd apps/api && .venv/bin/python -m pytest -q",
    "typecheck:wechat": "tsc -p apps/miniapp/tsconfig.json --noEmit",
    "build:wechat:check": "node scripts/build-wechat-miniprogram.mjs",
    "clean:wechat": "node scripts/clean-wechat-miniprogram.mjs",
    "check:wechat": "pnpm typecheck:wechat && pnpm build:wechat:check && node scripts/check-wechat-miniprogram.mjs"
  },
  "devDependencies": {
    "sass": "^1.89.2",
    "typescript": "^5.6.3"
  }
}
