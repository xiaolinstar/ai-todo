{
  "name": "@xiaolinstar/ai-todo-mcp",
  "version": "0.2.0",
  "description": "stdio MCP server for ai-todo (wraps ai-todo CLI)",
  "type": "commonjs",
  "bin": {
    "ai-todo-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "pnpm build && pnpm smoke"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaolinstar/ai-todo.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "ai-todo",
    "mcp",
    "model-context-protocol",
    "reminders",
    "calendar",
    "agent",
    "cursor"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3"
  }
}
